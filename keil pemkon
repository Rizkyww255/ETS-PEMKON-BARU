static uint32_t Clamp_Percent(uint32_t value);
/* USER CODE END PFP */

/* Private user code ---------------------------------------------------------*/
/* USER CODE BEGIN 0 */
static uint32_t Clamp_Percent(uint32_t value)
{
  if (value > 100U)
  {
    return 100U;
  }
  return value;
}

static void Set_PWM_Percent(TIM_HandleTypeDef *htim, uint32_t channel, uint32_t percent)
{
  uint32_t compare_value;

  percent = Clamp_Percent(percent);
  compare_value = (percent * PWM_PERIOD) / 100U;
  __HAL_TIM_SET_COMPARE(htim, channel, compare_value);
}

static uint32_t Read_ADC_Value(ADC_HandleTypeDef *hadc)
{
  uint32_t value = 0;

  HAL_ADC_Start(hadc);

  if (HAL_ADC_PollForConversion(hadc, 10) == HAL_OK)
  {
    value = HAL_ADC_GetValue(hadc);
  }

  HAL_ADC_Stop(hadc);

  return value;
}
