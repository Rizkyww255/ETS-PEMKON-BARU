/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{

  /* USER CODE BEGIN 1 */

  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_ADC1_Init();
  MX_ADC2_Init();
  MX_TIM3_Init();
  MX_TIM4_Init();
  MX_USART1_UART_Init();
  /* USER CODE BEGIN 2 */
  char header[] = "t_ms,temp_c,ldr_raw,risk_percent,pwm_percent,status\r\n";

  HAL_ADCEx_Calibration_Start(&hadc1);
  HAL_ADCEx_Calibration_Start(&hadc2);

  HAL_TIM_PWM_Start(&htim4, TIM_CHANNEL_1);
  HAL_TIM_PWM_Start(&htim3, TIM_CHANNEL_3);

  Set_PWM_Percent(&htim4, TIM_CHANNEL_1, 0);
  Set_PWM_Percent(&htim3, TIM_CHANNEL_3, 0);
  HAL_GPIO_WritePin(GPIOB, GPIO_PIN_7, GPIO_PIN_RESET);

  HAL_UART_Transmit(&huart1, (uint8_t *)header, sizeof(header) - 1U, 100);
  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {
    uint32_t lm35_adc;
    uint32_t ldr_adc;
    uint32_t lm35_mv;
    uint32_t temp_x10;
    uint32_t temp_norm;
    uint32_t light_norm;
    uint32_t dark_percent;
    uint32_t risk_percent;
    uint32_t pwm_percent;
    const char *status;
    char msg[96];
    int len;

    lm35_adc = Read_ADC_Value(&hadc1);
    ldr_adc = Read_ADC_Value(&hadc2);

    if (filter_initialized == 0U)
    {
      filtered_lm35_adc = lm35_adc;
      filtered_ldr_adc = ldr_adc;
      filter_initialized = 1U;
    }
    else
    {
      filtered_lm35_adc = ((filtered_lm35_adc * 3U) + lm35_adc) / 4U;
      filtered_ldr_adc = ((filtered_ldr_adc * 3U) + ldr_adc) / 4U;
    }

    lm35_mv = (filtered_lm35_adc * ADC_VREF_MV) / ADC_MAX_VALUE;
    temp_x10 = lm35_mv;

    if (temp_x10 <= TEMP_MIN_X10)
    {
      temp_norm = 0U;
    }
    else if (temp_x10 >= TEMP_MAX_X10)
    {
      temp_norm = 100U;
    }
    else
    {
      temp_norm = ((temp_x10 - TEMP_MIN_X10) * 100U) /
                  (TEMP_MAX_X10 - TEMP_MIN_X10);
    }

    light_norm = (filtered_ldr_adc * 100U) / ADC_MAX_VALUE;
    light_norm = Clamp_Percent(light_norm);
    dark_percent = 100U - light_norm;

    risk_percent = ((70U * temp_norm) + (30U * dark_percent)) / 100U;
    risk_percent = Clamp_Percent(risk_percent);

    if (risk_percent < 30U)
    {
      pwm_percent = 20U;
      status = "NORMAL";
      HAL_GPIO_WritePin(GPIOB, GPIO_PIN_7, GPIO_PIN_RESET);
      Set_PWM_Percent(&htim3, TIM_CHANNEL_3, 30U);
    }
    else if (risk_percent < 70U)
    {
      pwm_percent = 40U + (((risk_percent - 30U) * 50U) / 40U);
      status = "ADAPTIVE";
      HAL_GPIO_WritePin(GPIOB, GPIO_PIN_7, GPIO_PIN_RESET);
      Set_PWM_Percent(&htim3, TIM_CHANNEL_3, 70U);
    }
    else
    {
      pwm_percent = 100U;
      status = "ALERT";
      HAL_GPIO_WritePin(GPIOB, GPIO_PIN_7, GPIO_PIN_SET);
      Set_PWM_Percent(&htim3, TIM_CHANNEL_3, 0U);
    }

    Set_PWM_Percent(&htim4, TIM_CHANNEL_1, pwm_percent);

    len = sprintf(msg, "%lu,%lu.%lu,%lu,%lu,%lu,%s\r\n",
                  (unsigned long)HAL_GetTick(),
                  (unsigned long)(temp_x10 / 10U),
                  (unsigned long)(temp_x10 % 10U),
                  (unsigned long)filtered_ldr_adc,
                  (unsigned long)risk_percent,
                  (unsigned long)pwm_percent,
                  status);

    if (len > 0)
    {
      HAL_UART_Transmit(&huart1, (uint8_t *)msg, (uint16_t)len, 100);
    }

    HAL_Delay(100);
    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
  }
  /* USER CODE END 3 */
}

