#define ADC_MAX_VALUE      4095U
#define ADC_VREF_MV        3300U
#define PWM_PERIOD         999U
#define TEMP_MIN_X10       250U
#define TEMP_MAX_X10       600U

static uint32_t filtered_lm35_adc = 0;
static uint32_t filtered_ldr_adc = 0;
static uint8_t filter_initialized = 0;
